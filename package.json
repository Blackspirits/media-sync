{
  "name": "media-sync",
  "version": "1.0.0",
  "description": "Build pipeline for media-sync userscripts",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "rollup -c",
    "build:watch": "rollup -c --watch",
    "build:filmin": "rollup -c --environment SERVICE:filmin",
    "build:filmtwist": "rollup -c --environment SERVICE:filmtwist",
    "build:pandaplus": "rollup -c --environment SERVICE:pandaplus",
    "build:tvcine": "rollup -c --environment SERVICE:tvcine",
    "build:zigzag": "rollup -c --environment SERVICE:zigzag"
  },
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "rollup": "^4.18.0"
  }
}
